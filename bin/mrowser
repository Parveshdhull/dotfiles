#!/run/current-system/sw/bin/bash

if [[ $1 ]]; then
  s=$1
else
  s=$(xclip -o)
fi

if [[ $s = '' ]]; then
  s="https://www.google.com"
fi

if [[ $s == "www"* ]] || [[ $s == "http"* ]] || [[ $s == "com"* ]]; then
  mullvad-browser --profile /home/$USER/.mullvad/mullvadbrowser/n7shefun.default --private-window $s >/dev/null 2>&1 &
  disown
else
  mullvad-browser --profile /home/$USER/.mullvad/mullvadbrowser/n7shefun.default --private-window https://www.google.com/search?q="$s" >/dev/null 2>&1 &
  disown
fi
