#!/run/current-system/sw/bin/bash
set -euo pipefail

if [[ $EUID -ne 0 ]]; then
   echo "This script must be run as root"
   exit 1
fi

mkdir -p ~/.config/pconfig
TOGGLE=$HOME/.config/pconfig/.vpn

# Params
: ${LAN_INTERFACE:=enp7s0}
: ${WIREGUARD_INTERFACE:=wg0}
: ${ROUTE_IP:=192.168.1.1}
: ${WIREGUARD_SERVER_PUBLIC_KEY:=$WIREGUARD_ALTAIR}
: ${ALLOWED_IPS:=10.100.0.1/32,10.100.0.4/32}

# Route whole network
if [ ! -e $TOGGLE ]; then
  touch $TOGGLE
  sudo wg set $WIREGUARD_INTERFACE peer $WIREGUARD_SERVER_PUBLIC_KEY allowed-ips 0.0.0.0/0
  sudo ip route add default dev $WIREGUARD_INTERFACE
  sudo ip route add $SERVER_IP via $ROUTE_IP dev $LAN_INTERFACE
else # Split network
  trash $TOGGLE
  sudo wg set $WIREGUARD_INTERFACE peer $WIREGUARD_SERVER_PUBLIC_KEY allowed-ips $ALLOWED_IPS
  sudo ip route del default dev $WIREGUARD_INTERFACE
  sudo ip route del $SERVER_IP via $ROUTE_IP dev $LAN_INTERFACE
fi
