#!/run/current-system/sw/bin/bash
set -euo pipefail

mkdir -p ~/.config/pconfig
TOGGLE=$HOME/.config/pconfig/.vpn

# Route full network
if [ ! -e $TOGGLE ]; then
  touch $TOGGLE
  sudo wg set wg0 peer $WIREGUARD_ALTAIR allowed-ips 0.0.0.0/0
  sudo ip route add default dev wg0
  sudo ip route add $SERVER_IP via 192.168.1.1 dev enp7s0
else # Split network
  trash $TOGGLE
  sudo wg set wg0 peer $WIREGUARD_ALTAIR allowed-ips 10.100.0.1/32,10.100.0.4/32
  sudo ip route del default dev wg0
  sudo ip route del $SERVER_IP via 192.168.1.1 dev enp7s0
fi
