#!/run/current-system/sw/bin/bash

if [[ $1 ]]; then
  s=$1
else
  s=$(xclip -o)
fi

if [[ $s = '' ]]; then
  s="https://www.google.com"
fi

if [[ $s == "www"* ]] || [[ $s == "http"* ]] || [[ $s == "com"* ]]; then
  librewolf --profile /home/monu/.librewolf/sbu8ja1o.default --private-window $s >/dev/null 2>&1 &
  disown
else
  librewolf --profile /home/monu/.librewolf/sbu8ja1o.default --private-window https://www.google.com/search?q="$s" >/dev/null 2>&1 &
  disown
fi
